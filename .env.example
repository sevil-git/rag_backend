# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=is456-slab-design

# LLM provider: ollama or gemini
LLM_PROVIDER=ollama

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
# Optional regex for dynamic frontend domains (e.g. Vercel preview URLs)
FRONTEND_ORIGIN_REGEX=^https://.*\.vercel\.app$|^http://(localhost|127\.0\.0\.1)(:\d+)?$

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Embedding model (HuggingFace)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# PDF path (relative to rag_backend/)
PDF_PATH=../is.456.2000 (1).pdf
PDF_SOURCE_LABEL=IS 456:2000
